# Database (recommended pooled Neon URL)
POSTGRES_URL=
# Fallback aliases (optional)
DATABASE_URL=
POSTGRES_URL_NON_POOLING=

# Session signing secret
FLASK_SECRET_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
# Optional override (if omitted, code builds endpoint from R2_ACCOUNT_ID)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
